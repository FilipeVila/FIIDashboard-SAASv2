{
  "version": 2,
  "builds": [
    {
      "src": "backend-python/main.py",
      "use": "@vercel/python"
    },
    {
      "src": "frontend/public/**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "backend-python/main.py"
    },
    {
      "src": "/css/(.*)",
      "dest": "frontend/public/css/$1"
    },
    {
      "src": "/js/(.*)",
      "dest": "frontend/public/js/$1"
    },
    {
      "src": "/(.*)",
      "dest": "frontend/public/index.html"
    }
  ]
}
